# Copy this file to .env and adjust the values before running docker compose.

# Use {database} as the placeholder. The backup script replaces it with each
# database name listed in DATABASES.
SQLSERVER_CONNECTION_STRING=Server=tcp:example.database.windows.net,1433;Database={database};User ID=sa;Password=change-me;Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;

# Comma-separated database names.
DATABASES=Database1,Database2

# Five-field cron expression. Default: every Thursday at 05:00.
CRON_EXPRESSION=0 5 * * 4

# Container backup directory and host bind mount path.
BACKUP_DIR=/backups
HOST_BACKUP_DIR=./backups

# Keep the newest N .bacpac files per database.
RETENTION_COUNT=5

# Run one backup immediately when the container starts.
RUN_ON_STARTUP=false

# Time zone used by cron and timestamps. Examples: UTC, Asia/Shanghai, Asia/Taipei.
TZ=UTC

# Optional extra sqlpackage arguments. Example:
# SQLPACKAGE_EXTRA_ARGS=/p:CommandTimeout=120
SQLPACKAGE_EXTRA_ARGS=
